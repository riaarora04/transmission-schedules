<mvc:View
    controllerName="transmissionschedules.controller.ListReport"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <f:DynamicPage
                id="dynamicPageId"
                toggleHeaderOnTitleClick="false">

                <!-- Dynamic Page Title -->
                <f:title>
                    <f:DynamicPageTitle>
                        <f:heading>
                            <Title text="{i18n>listReportTitle}" level="H1"/>
                        </f:heading>
                        <f:actions>
                            <Button
                                text="{i18n>createButton}"
                                type="Emphasized"
                                press=".onCreateSchedule"/>
                        </f:actions>
                    </f:DynamicPageTitle>
                </f:title>

                <!-- Dynamic Page Header -->
                <f:header>
                    <f:DynamicPageHeader pinnable="true">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar class="sapUiTinyMarginBottom">
                                <Title text="Filters" level="H3"/>
                                <ToolbarSpacer/>
                                <Button
                                    text="Go"
                                    type="Emphasized"
                                    press=".onSearch"/>
                                <Button
                                    text="Clear"
                                    press=".onReset"/>
                            </Toolbar>

                            <layout:Grid
                                defaultSpan="L4 M6 S12"
                                hSpacing="1"
                                vSpacing="1">
                                <VBox>
                                    <Label text="{i18n>scheduleId}" labelFor="scheduleIdFilter"/>
                                    <Input
                                        id="scheduleIdFilter"
                                        placeholder="{i18n>enterScheduleId}"/>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>status}" labelFor="statusFilter"/>
                                    <Select
                                        id="statusFilter"
                                        items="{path: 'schedules>/statusValues'}">
                                        <core:Item key="{schedules>key}" text="{schedules>text}"/>
                                    </Select>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>category}" labelFor="categoryFilter"/>
                                    <Input
                                        id="categoryFilter"
                                        placeholder="{i18n>enterCategory}"/>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>issueType}" labelFor="issueTypeFilter"/>
                                    <Input
                                        id="issueTypeFilter"
                                        placeholder="{i18n>enterIssueType}"/>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>soldToParty}" labelFor="soldToPartyFilter"/>
                                    <Input
                                        id="soldToPartyFilter"
                                        placeholder="{i18n>enterSoldToParty}"/>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>validFrom}" labelFor="validFromFilter"/>
                                    <DatePicker
                                        id="validFromFilter"
                                        placeholder="{i18n>selectDate}"/>
                                </VBox>

                                <VBox>
                                    <Label text="{i18n>validTo}" labelFor="validToFilter"/>
                                    <DatePicker
                                        id="validToFilter"
                                        placeholder="{i18n>selectDate}"/>
                                </VBox>
                            </layout:Grid>
                        </VBox>
                    </f:DynamicPageHeader>
                </f:header>

                <!-- Dynamic Page Content -->
                <f:content>
                    <Table
                        id="schedulesTable"
                        mode="SingleSelectMaster"
                        items="{
                            path: 'schedules>/schedules',
                            sorter: {
                                path: 'scheduleId',
                                descending: false
                            }
                        }"
                        selectionChange=".onSelectionChange"
                        growing="true"
                        growingThreshold="20"
                        sticky="ColumnHeaders,HeaderToolbar">

                        <headerToolbar>
                            <OverflowToolbar>
                                <Title
                                    text="{i18n>schedules}"
                                    level="H2"/>
                                <ToolbarSpacer/>
                                <OverflowToolbarButton
                                    icon="sap-icon://sort"
                                    text="{i18n>sort}"
                                    press=".onSort"/>
                                <OverflowToolbarButton
                                    icon="sap-icon://excel-attachment"
                                    text="{i18n>export}"
                                    press=".onExport"/>
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>
                            <Column
                                width="12%"
                                demandPopin="true"
                                minScreenWidth="Tablet">
                                <Text text="{i18n>scheduleId}"/>
                            </Column>
                            <Column
                                width="10%"
                                demandPopin="true"
                                minScreenWidth="Desktop">
                                <Text text="{i18n>status}"/>
                            </Column>
                            <Column
                                width="15%"
                                demandPopin="true"
                                minScreenWidth="Tablet">
                                <Text text="{i18n>category}"/>
                            </Column>
                            <Column
                                width="15%"
                                demandPopin="true"
                                minScreenWidth="Desktop">
                                <Text text="{i18n>issueType}"/>
                            </Column>
                            <Column
                                width="15%"
                                demandPopin="true"
                                minScreenWidth="Tablet">
                                <Text text="{i18n>soldToParty}"/>
                            </Column>
                            <Column
                                width="12%"
                                demandPopin="true"
                                minScreenWidth="Desktop">
                                <Text text="{i18n>validFrom}"/>
                            </Column>
                            <Column
                                width="12%"
                                demandPopin="true"
                                minScreenWidth="Desktop">
                                <Text text="{i18n>validTo}"/>
                            </Column>
                            <Column
                                width="9%"
                                hAlign="Center">
                                <Text text="{i18n>frequency}"/>
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem type="Navigation">
                                <cells>
                                    <ObjectIdentifier
                                        title="{schedules>scheduleId}"
                                        text="{schedules>description}"/>
                                    <ObjectStatus
                                        text="{schedules>status}"
                                        state="{
                                            path: 'schedules>status',
                                            formatter: '.formatStatusState'
                                        }"/>
                                    <Text text="{schedules>category}"/>
                                    <Text text="{schedules>issueType}"/>
                                    <Text text="{schedules>soldToParty}"/>
                                    <Text text="{
                                        path: 'schedules>validFrom',
                                        type: 'sap.ui.model.type.Date',
                                        formatOptions: {
                                            pattern: 'dd/MM/yyyy'
                                        }
                                    }"/>
                                    <Text text="{
                                        path: 'schedules>validTo',
                                        type: 'sap.ui.model.type.Date',
                                        formatOptions: {
                                            pattern: 'dd/MM/yyyy'
                                        }
                                    }"/>
                                    <Text text="{schedules>frequency}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </f:content>
            </f:DynamicPage>
</mvc:View>
