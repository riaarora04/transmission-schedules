# SAP BTP Configuration
SAP_BTP_HOST=https://your-account.cfapps.eu10.hana.ondemand.com
SAP_CLIENT_ID=your-oauth-client-id
SAP_CLIENT_SECRET=your-oauth-client-secret
SAP_TOKEN_URL=https://your-account.authentication.eu10.hana.ondemand.com/oauth/token

# OData Service Endpoints
SAP_ODATA_SERVICE_ROOT=/sap/opu/odata/sap
SAP_API_BUSINESS_PARTNER=/API_BUSINESS_PARTNER
SAP_API_SALES_ORDER=/API_SALES_ORDER_SRV
SAP_API_MATERIAL=/API_MATERIAL_STOCK_SRV

# Development Mode
MOCK_MODE=true
MOCK_DELAY_MS=500

# Logging
LOG_LEVEL=info
