<mvc:View
    controllerName="com.sap.selfbilling.documentparsing.controller.Launchpad"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    height="100%">

    <Page
        showHeader="true"
        showNavButton="false"
        class="sapUiContentPadding">

        <!-- Shell Bar -->
        <customHeader>
            <f:ShellBar
                title="Home"
                showMenuButton="true"
                showNavButton="true"
                showCopilot="false"
                showSearch="true"
                showNotifications="true"
                showProductSwitcher="false"
                notificationsNumber="0">
                <f:profile>
                    <Avatar
                        initials="SD"
                        backgroundColor="Accent6"/>
                </f:profile>
            </f:ShellBar>
        </customHeader>

        <!-- Icon Tab Bar -->
        <subHeader>
            <IconTabBar
                id="iconTabBar"
                select=".onTabSelect"
                class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter
                        text="{i18n>launchpadTitle}"
                        key="selfBilling"
                        design="Horizontal"/>
                    <IconTabFilter
                        text="Self-Billing Analytics"
                        key="analytics"
                        design="Horizontal"/>
                    <IconTabFilter
                        text="Self-Billing Configuration"
                        key="configuration"
                        design="Horizontal"/>
                    <IconTabFilter
                        text="Self-Billing Archiving"
                        key="archiving"
                        design="Horizontal"/>
                    <IconTabFilter
                        text="Self-Billing Logs"
                        key="logs"
                        design="Horizontal"/>
                </items>
            </IconTabBar>
        </subHeader>

        <content>
            <ScrollContainer
                height="100%"
                width="100%"
                vertical="true"
                horizontal="false">

                <VBox class="sapUiMediumMarginTop sapUiLargeMarginBegin sapUiLargeMarginEnd">

                    <!-- First Section -->
                    <VBox class="sapUiSmallMarginBottom">
                        <HBox class="sapUiSmallMarginBottom">
                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="{i18n>tile1Title}"
                                subheader="{i18n>tile1Subtitle}"
                                frameType="TwoByOne"
                                press=".onTilePress">
                                <TileContent>
                                    <ImageContent src="sap-icon://document"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="{i18n>tile2Title}"
                                subheader="{i18n>tile2Subtitle}"
                                frameType="TwoByOne"
                                press=".onTilePress">
                                <TileContent>
                                    <ImageContent src="sap-icon://document"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                id="aiTile"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="{i18n>tile3Title}"
                                frameType="TwoByOne"
                                press=".onAITilePress">
                                <TileContent>
                                    <ImageContent src="sap-icon://ai"/>
                                </TileContent>
                            </GenericTile>
                        </HBox>
                    </VBox>

                    <!-- Analytics Section -->
                    <VBox class="sapUiMediumMarginTop">
                        <Title text="{i18n>analyticsTitle}" level="H2" class="sapUiSmallMarginBottom"/>
                        <HBox class="sapUiSmallMarginBottom">
                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Manage Price Deviation"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://trend-up"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Manage Quantity Deviation"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://measuring-point"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Manage Tax Deviation"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://message-warning"/>
                                </TileContent>
                            </GenericTile>
                        </HBox>
                    </VBox>

                    <!-- Configuration Section -->
                    <VBox class="sapUiMediumMarginTop">
                        <Title text="{i18n>configTitle}" level="H2" class="sapUiSmallMarginBottom"/>
                        <HBox wrap="Wrap">
                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Manage Tolerance Group"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://settings"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Define Sold-to Party Parameters"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://customer"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Define Sender Parameters"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://email"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Define General Parameters"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://customize"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                header="Customize Self Billing Process"
                                frameType="TwoByOne">
                                <TileContent>
                                    <ImageContent src="sap-icon://workflow-tasks"/>
                                </TileContent>
                            </GenericTile>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
